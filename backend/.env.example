# --- Groq (FREE tier) — used for Whisper transcription AND LLM chat ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_free_key_here

# Models (Groq free tier)
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# --- Embeddings: local fastembed (no key, no cost) ---
EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Qdrant ---
# LOCAL (dev): on-disk mode, no setup.
QDRANT_PATH=./qdrant_data
# CLOUD (deploy): set these two and the app stores vectors + sessions + cache in the cloud
# (no local disk). Get a free 1GB cluster at https://cloud.qdrant.io (no card).
# QDRANT_URL=https://xxxx.cloud.qdrant.io:6333
# QDRANT_API_KEY=your_qdrant_cloud_key

# Storage backend for cache/sessions: "local" (JSON files) or "qdrant" (in the DB).
# Auto-selects "qdrant" when QDRANT_URL is set; override here to test the cloud path locally.
# STORAGE_BACKEND=local

# --- CORS: the deployed frontend origin(s), comma-separated ---
CORS_ORIGINS=http://localhost:3000

# --- Instagram auth (IG blocks anonymous yt-dlp — REQUIRED for reels) ---
# RELIABLE on Windows: export cookies.txt while logged into Instagram, then:
#   1. Add the "Get cookies.txt LOCALLY" extension to Chrome/Edge
#   2. Log into instagram.com, click the extension -> Export -> save as backend/cookies.txt
IG_COOKIES_FILE=./cookies.txt
#
# NOTE: IG_COOKIES_FROM_BROWSER=chrome|edge FAILS on Windows (DPAPI/app-bound cookie
# encryption, yt-dlp #10927). Only use it with Firefox (IG_COOKIES_FROM_BROWSER=firefox).
# IG_COOKIES_FROM_BROWSER=firefox
#
# CLOUD (deploy): can't ship a file, so pass cookies.txt as a base64 secret instead.
# Generate:  python -c "import base64;print(base64.b64encode(open('cookies.txt','rb').read()).decode())"
# IG_COOKIES_B64=base64_of_your_cookies_txt
